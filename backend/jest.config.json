{
  "testEnvironment": "node",
  "testMatch": ["**/__tests__/**/*.test.js", "**/?(*.)+(spec|test).js"],
  "collectCoverageFrom": [
    "**/*.js",
    "!**/node_modules/**",
    "!**/config/**",
    "!**/coverage/**"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "lcov", "html"],
  "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
  "transform": {
    "^.+\\.js$": ["babel-jest", { "configFile": "./babel.config.js" }]
  },
  "globals": {
    "babel-jest": {
      "useESM": true
    }
  }
}