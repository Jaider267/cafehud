{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "rootDirs": [".", "./.react-router/types"]
  },
  "include": [
    "app/**/*",
    "src/**/*",
    ".react-router/types/**/*",
    "react-router.config.js",
    "vite.config.js"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist"
  ]
}
